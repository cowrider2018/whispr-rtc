# Copy this file to `.env` and fill in ONE value: your ngrok authtoken.
#   cp .env.example .env
#
# `.env` is gitignored — never commit real secrets.
#
# You only need NGROK_AUTHTOKEN. Everything else is derived from it at runtime:
# start-call.bat launches ngrok with this token and reads the assigned public
# https:// URL back from ngrok's local API (http://127.0.0.1:4040) — you don't
# configure a domain.

# ngrok authtoken (SECRET). Get it at:
#   https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=paste-your-ngrok-authtoken-here

# Optional (advanced): pin a reserved domain for a stable URL. Not required.
# Claim one free at https://dashboard.ngrok.com/domains
#NGROK_DOMAIN=
